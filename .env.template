# ============================================================
# Gaze Attention Monitoring System — Environment Variables
# ============================================================
# Copy this to .env and fill in your values.

# Server Configuration
STUDENT_APP_PORT=5001
BACKEND_PORT=5002
BACKEND_URL=http://127.0.0.1:5002

# Debug Mode (set to False in production)
DEBUG=True

# Secret Key (generate a random string for production)
SECRET_KEY=development-secret-key-change-in-production

# Teacher Password
TEACHER_PASSWORD=teacher123

# ============================================================
# SSL / HTTPS (optional — required for non-localhost deployment)
# ============================================================
SSL_ENABLED=False
SSL_CERT_PATH=
SSL_KEY_PATH=

# ============================================================
# TURN Server (optional — required for NAT/firewall traversal)
# ============================================================
# Free TURN servers: https://www.metered.ca/stun-turn
# Example: turn:global.relay.metered.ca:443?transport=tcp
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_PER_SID=2
RATE_LIMIT_PER_IP=20
MAX_CONNECTIONS_PER_IP=10
