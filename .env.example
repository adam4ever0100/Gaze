# Environment Configuration for Gaze
# Copy this file to .env and fill in your values

# Server Ports
STUDENT_APP_PORT=5001
BACKEND_PORT=5002

# Teacher Authentication
TEACHER_PASSWORD=teacher123

# Security
SECRET_KEY=change-this-to-a-random-secret-key

# Debug Mode (set to False in production)
DEBUG=True

# TURN Server (optional — for WebRTC behind strict firewalls)
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=

# LiveKit SFU Server
# For local dev: devkey/secret and ws://localhost:7880
# For production: sign up at https://cloud.livekit.io (free tier)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=ws://localhost:7880

# SSL (only if NOT using reverse proxy)
SSL_ENABLED=False
SSL_CERT_PATH=
SSL_KEY_PATH=

# Rate Limiting
RATE_LIMIT_PER_SID=5
RATE_LIMIT_PER_IP=60
MAX_CONNECTIONS_PER_IP=30
MAX_STUDENTS_PER_ROOM=25
