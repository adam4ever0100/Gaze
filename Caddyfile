# Gaze — Caddy Reverse Proxy
# Automatic HTTPS with Let's Encrypt

gaze-classroom.duckdns.org {
    # Socket.IO — always goes to backend
    handle /socket.io/* {
        reverse_proxy backend:5002
    }

    # Teacher Dashboard — redirect bare /teacher to /teacher/
    handle /teacher {
        redir * /teacher/ 301
    }

    # Teacher Dashboard — everything under /teacher/
    handle /teacher/* {
        uri strip_prefix /teacher
        reverse_proxy backend:5002
    }

    # Backend API endpoints — sessions (PDF/reports/summary), api/*, config
    handle /sessions/* {
        reverse_proxy backend:5002
    }

    handle /api/* {
        reverse_proxy backend:5002
    }

    handle /config {
        reverse_proxy backend:5002
    }

    # Student App (catch-all)
    handle {
        reverse_proxy student-app:5001
    }
}
